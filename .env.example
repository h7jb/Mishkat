# توكن البوت الخاص بك من Discord Developer Portal
DISCORD_TOKEN=your_bot_token_here

# معرف تطبيق البوت (Client ID)
CLIENT_ID=your_client_id_here

# المنفذ الخاص بخادم الويب (مطلوب لاستضافة Render)
PORT=3000

# معرف السيرفر الأساسي لمالك البوت (لحماية أمر /admin وقصره على هذا السيرفر فقط)
MAIN_GUILD_ID=your_main_guild_id_here

# رابط خدمة Render الخاص بك (لتفعيل نظام Keep-Alive ومنع السكون 24/7)
RENDER_EXTERNAL_URL=https://your-bot-app.onrender.com
